# DOCUMENT INTELLIGENCE - CONFIGURACION
# Copia este archivo como .env y completa los valores.
# NUNCA subas tu .env al repositorio.

# La plataforma funciona en modo FREE-FIRST offline sin ninguna API Key.

# Django
DEBUG=True
SECRET_KEY=genera_una_clave_segura_aqui
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de Datos
DB_NAME=nombre_base_datos
DB_USER=usuario
DB_PASSWORD=contrase�a
DB_HOST=localhost
DB_PORT=5432

# Proveedor IA principal (gemini, deepseek, openrouter, qwen)
AI_PROVIDER=gemini

# Gemini (Google) - RECOMENDADO (gratuito, soporta OCR/imagenes)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo Gemini (default: gemini-2.5-flash, recomendado por Google AI Studio)
# Cambia este valor si Google actualiza el modelo, sin tocar código.
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek - Alternativa gratuita (solo texto)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter - Acceso a multiples modelos
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Qwen (Alibaba Cloud) - Alternativa gratuita
# https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# Cloudinary (opcional)
# CLOUDINARY_URL=
