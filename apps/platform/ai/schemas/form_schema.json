{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Form Schema",
  "description": "Schema for AI-generated form proposals",
  "type": "object",
  "properties": {
    "form_name": {
      "type": "string",
      "description": "Suggested form name"
    },
    "form_description": {
      "type": "string",
      "description": "Form description"
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "field_schema.json"
      },
      "description": "List of detected/suggested fields"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall confidence score"
    },
    "source_document": {
      "type": "string",
      "description": "Source document name"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Analysis warnings"
    }
  },
  "required": ["form_name", "fields"]
}
